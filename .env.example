# ArcPay Bot - Arc Testnet Payment Bot
# Copy to .env and fill in your values
#
# NOTE: On Arc Network, USDC is the NATIVE gas token (chain id 5042002).
# All transactions are native value transfers, NOT ERC20 calls.

# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# --- Arc Testnet ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# --- Wallet Encryption ---
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_ENCRYPTION_KEY=

# --- Database ---
DATABASE_PATH=./data/arcpay.db

# --- Escrow Contract (deployed on Arc testnet) ---
ESCROW_CONTRACT_ADDRESS=0x67aF28a3383b1c1343D7264EEc90a3aD87A7a72A

# --- Render ---
PORT=10000
